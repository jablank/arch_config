# See @ https://wiki.hypr.land/Configuring/Keywords/
# Rofi skins @ https://github.com/adi1090x/rofi?tab=readme-ov-file
# https://docs.noctalia.dev/getting-started/keybinds/
#
# mainMod + zxcv for workspaces 1-4 for navigation and shift moving wind
# wasd focus/window swapping
# reset waybar with hotkey = waybar pkill waybar && exec waybar &  


################
### Defaults ###
################

$mainMod = SUPER

$launcher = qs -c noctalia-shell ipc call launcher toggle # /home/jab/.config/rofi/launchers/type-3/launcher.sh
$lock = qs -c noctalia-shell ipc call lockScreen lock

$browser = ~/AppImages/helium.appimage  
$terminal = kitty
$filemanager = nautilus

$smartfloater = /home/jab/.config/hypr/smart_floater.sh
$screenshot = sh -c 'slurp | grim -g - /home/jab/Pictures/Screenshots/$(date +%Y%m%d_%H%M).png'

$l = a
$r = d
$u = w
$d = s

####################
### Noct Hotkeys ###
####################

bind = $mainMod, I, exec, qs -c noctalia-shell ipc call settings toggle
bind = $mainMod SHIFT, E, exec, qs -c noctalia-shell ipc call sessionMenu toggle
bind = $mainMod SHIFT, W, exec, qs -c noctalia-shell ipc call wallpaper toggle

bindel = , XF86AudioRaiseVolume, exec, qs -c noctalia-shell ipc call volume increase
bindel = , XF86AudioLowerVolume, exec, qs -c noctalia-shell ipc call volume decrease
bindel = , XF86AudioMute, exec, qs -c noctalia-shell ipc call volume muteOutput
bindl = , XF86AudioPause, exec, qs -c noctalia-shell ipc call media playPause
bindl = , XF86AudioPlay, exec, qs -c noctalia-shell ipc call media playPause
bindl = , XF86AudioNext, exec, qs -c noctalia-shell ipc call media next
bindl = , XF86AudioPrev, exec, qs -c noctalia-shell ipc call media previous

####################
### Base Hotkeys ###
####################

# bind = $mainMod SHIFT, M, exit,
bind = $mainMod, L, exec, $lock # hyprlock
bind = $mainMod, Q, killactive,
bind = $mainMod, F, fullscreen
# togglefloating autoresizes
bind = $mainMod, G, exec, $smartfloater
bind = $mainMod, Tab, cyclenext, tiled
bind = $mainMod, Space, cyclenext, floating

bind = $mainMod, E, exec, $filemanager
bind = $mainMod, 4, exec, $browser
bind = $mainMod, R, exec, $launcher
bind = $mainMod, T, exec, $terminal

bind = $mainMod SHIFT, space, exec, $screenshot 
bind = $mainMod SHIFT, T, exec, [float;size 30% 35%;center] foot

bind = $mainMod, 6, exec, hyprpicker -f hex


# Move focus 

bind = $mainMod, $l, movefocus, l
bind = $mainMod, $r, movefocus, r
bind = $mainMod, $u, movefocus, u
bind = $mainMod, $d, movefocus, d

# Workspaces

bind = $mainMod, Z, workspace, 1
bind = $mainMod, X, workspace, 2
bind = $mainMod, C, workspace, 3
bind = $mainMod, V, workspace, 4

bind = $mainMod SHIFT, Z, movetoworkspace, 1
bind = $mainMod SHIFT, X, movetoworkspace, 2
bind = $mainMod SHIFT, C, movetoworkspace, 3
bind = $mainMod SHIFT, V, movetoworkspace, 4

bind = $mainMod SHIFT, $l, swapwindow, l
bind = $mainMod SHIFT, $r, swapwindow, r
bind = $mainMod SHIFT, $u, swapwindow, u
bind = $mainMod SHIFT, $d, swapwindow, d

# bind = $mainMod, mouse_down, workspace, e+1
# bind = $mainMod, mouse_up, workspace, e-1
bindm = $mainMod, mouse:272, movewindow
bindm = $mainMod, mouse:273, resizewindow

# Devices
#bindel = ,XF86AudioRaiseVolume, exec, swayosd-client --output-volume 4 raise --max-volume 100
#bindel = ,XF86AudioLowerVolume, exec, swayosd-client --output-volume 4 lower --max-volume 100 
#bindel = ,XF86AudioMute, exec, swayosd-client mute-toggle
#bindl = , XF86AudioNext, exec, playerctl next
#bindl = , XF86AudioPause, exec, playerctl play-pause
#bindl = , XF86AudioPlay, exec, playerctl play-pause
#bindl = , XF86AudioPrev, exec, playerctl previous

bindel = ,XF86AudioMicMute, exec, wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle

 
