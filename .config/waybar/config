{
    "layer": "top",
    "position": "top",
    "height": 26,
    "spacing": 5,

    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["tray", "memory", "network", "wireplumber"],

    "hyprland/workspaces": {
        "format": "<span size='larger'>{icon}</span>",
        "on-click": "activate",
        "format-icons": {
            "active": "\uf444",
            "default": "\uf4c3"
        },
        "icon-size": 10,
        "sort-by-number": true,
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
        }
    },
        
    "clock": {
        "format": "{:%Y %b %d  %H:%M}"
    },
    
    "tray": {
        "icon-size": 16,
        "spacing": 16
    },
    
"wireplumber": {
    "format": "{icon} {volume}%",
    "format-muted": " Muted", // Unicode for speaker-off
    "tooltip": true,
    "format-icons": {
        "headphone": "", // Unicode for music note/headphone
        "phone": "",     // Unicode for phone
        "portable": "",  // Unicode for phone/portable
        "car": "",      // Unicode for car
        "default": ["", "", ""] // Unicodes for volume low, medium, high
    },
    // Optional: map to specific device
    "on-click": "pavucontrol"
},

"memory": {
    "interval": 30,
    "format": "\uf4bc {used:0.1f}G "
    },


"network": {
    "format-icons": {
        "default": "󰤟", // Nerd Font Wi-Fi low
        "none": "󰤯",    // Nerd Font Wi-Fi disabled
        "full": "󰤨"     // Nerd Font Wi-Fi full
    },
    "format-wifi": "{icon} {essid}",
    "format-ethernet": "{icon} {ipaddr}",
},


    "temperature": {
        "format": "{temperatureC}°C"
    },

    "bluetooth": {
        "format": "\udb80\udcaf",
        "format-disabled": "\udb80\udcb2",
        "format-connected": "\udb80\udcb1",
        "tooltip-format": "{controller_alias}\t{controller_address}",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}"
    },

    "hyprland/language": {
        "format": "{short}"
    },

    "custom/platform-profile": {
	"format": "{icon} ",
	"exec": "~/.config/waybar/platform_profile.sh",
	"return-type": "json",
	"restart-interval": 1,
	"format-icons": {
	    "quiet": "\udb80\udf2a",
	    "balanced": "\udb80\ude10",
	    "performance": "\uf427",
            "default": "?"
	},
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "\udb80\udd76",
            "deactivated": "\udb83\udfaa"
        }
    }
}
